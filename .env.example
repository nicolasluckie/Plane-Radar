# DEBUG MODE - Enables verbose logging for troubleshooting
PLANERADAR_DEBUG=0

# MOCK DATA MODE - Uses data-sample.json instead of live API
PLANERADAR_MOCK_DATA=0

# Location (latitude/longitude)
# Example: Toronto Pearson Airport
PLANERADAR_LAT=43.6777
PLANERADAR_LON=-79.6248

# ADS-B Fetch Interval (milliseconds)
PLANERADAR_FETCH_INTERVAL_MS=5000

# ADS-B API Base URL
PLANERADAR_API_BASE=https://opendata.adsb.fi/api/v3/lat/

# FETCH RADIUS (km) - Controls the API fetch radius from adsb.fi
# Determines how far out to request aircraft data (affects network bandwidth and data volume)
# Should be larger than or equal to RANGE PRESET (below)
PLANERADAR_FETCH_RADIUS_KM=15

# RANGE PRESET - Controls the visual display range on the circular TFT screen
# Presets: 0=5km, 1=10km, 2=15km, 3=25km
PLANERADAR_RANGE_INDEX=1

# DISTANCE UNITS (0=km, 1=miles)
PLANERADAR_USE_MILES=0

# Show Runway Overlay (0=false, 1=true)
PLANERADAR_SHOW_RUNWAYS=1

# WEB PORTAL (0.0.0.0 = accessible from other devices on network)
PLANERADAR_WEB_HOST=0.0.0.0
PLANERADAR_WEB_PORT=8080

# LOG LEVEL - Controls verbosity (debug, info, warning, error, critical)
# debug enables verbose output; warning is recommended for production
# Note: PLANERADAR_DEBUG=1 overrides this to debug regardless of value set here
PLANERADAR_LOG_LEVEL=warning

# LOG TO DISK - Write logs to the path below in addition to stderr (0=off, 1=on)
# Uses a 5 MB rotating file with 3 backups. Disabled by default to protect SD card longevity.
PLANERADAR_LOG_TO_DISK=0

# LOG PATH - File path for disk logging (only used when PLANERADAR_LOG_TO_DISK=1)
# Override to expose as a Docker volume mount (e.g. /logs/app.log)
PLANERADAR_LOG_PATH=/var/log/plane-radar/app.log
